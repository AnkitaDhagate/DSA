class Solution {
    static int countFactors(int n) {
        
        int count = 0;
        
        for(int i = 1; i * i <= n; i++)
        {
            if(n % i == 0)
            {
                count++;   // factor i
                
                if(i != n / i)
                    count++;   // paired factor
            }
        }
        
        return count;
    }
}
