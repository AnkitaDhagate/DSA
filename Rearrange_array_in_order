import java.util.*;

public class Rearrange_array_in_order {

	public static void main(String[] args) {

		int arr[] = {5, 2, 9, 1, 6, 3};
		int n = arr.length;
		Arrays.sort(arr);
		for(int i = n/2, j = n-1; i < j; i++, j--)
		{
			int temp = arr[i];
			arr[i] = arr[j];
			arr[j] = temp;
		}
		for(int i = 0; i < n; i++)
		{
			System.out.print(arr[i] + " ");
		}
	}
}
