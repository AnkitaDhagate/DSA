import java.util.Scanner;

public class MedianOfArray {

	public static void getMedian(int[]arr, int n)
	{
		if(n%2==0)
		{
			int index1 = (n/2) + 1;
			int index2 = (n/2);
			double evenMedian = (arr[index1]+arr[index2])/2;
			System.out.println(evenMedian);
		}
		else
		{
			double oddMedian = arr[n/2];
			System.out.println(oddMedian);
		}
	}
	public static void main(String[] args) {

		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int [] arr = new int[n];
		for(int i=0;i<arr.length;i++)
		{
			arr[i] = sc.nextInt();
		}
		MedianOfArray obj = new MedianOfArray();
		obj.getMedian(arr, n);
	}

}
